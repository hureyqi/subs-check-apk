<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Material 3) -->
    <style name="Theme.SubsCheckAPK" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/onPrimary</item>
        <item name="colorPrimaryContainer">@color/primaryVariant</item>
        <item name="colorOnPrimaryContainer">@color/onPrimary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/onSecondary</item>
        <item name="colorSecondaryContainer">@color/secondaryVariant</item>
        <item name="colorOnSecondaryContainer">@color/onSecondary</item>

        <!-- Tertiary brand color -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/onTertiary</item>

        <!-- Background and surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/onBackground</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/onSurface</item>
        <item name="colorSurfaceVariant">@color/surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/onSurfaceVariant</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/onError</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <!-- App Bar Style -->
    <style name="Theme.SubsCheckAPK.AppBarOverlay" parent="ThemeOverlay.Material3.ActionBar" />

    <!-- Popup Menu Style -->
    <style name="Theme.SubsCheckAPK.PopupOverlay" parent="ThemeOverlay.Material3.Light" />

    <!-- Card Style -->
    <style name="Theme.SubsCheckAPK.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- Button Styles -->
    <style name="Theme.SubsCheckAPK.Button" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Theme.SubsCheckAPK.Button.Elevated" parent="Widget.Material3.Button.ElevatedButton">
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Input Style -->
    <style name="Theme.SubsCheckAPK.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>
</resources>
